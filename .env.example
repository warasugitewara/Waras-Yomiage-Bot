# Discord Bot Token（必須）
DISCORD_TOKEN=your_token_here

# VOICEVOX ENGINE の URL
VOICEVOX_URL=http://localhost:50021

# コマンドプレフィックス
PREFIX=!y

# デフォルトスピーカーID（3 = ずんだもん ノーマル）
DEFAULT_SPEAKER=3

# デフォルト読み上げ速度（0.5 〜 2.0）
DEFAULT_SPEED=1.0

# 最大読み上げ文字数（超えた分は「...」でカット）
MAX_TEXT_LENGTH=100

# スラッシュコマンドをギルド限定で即時同期する場合は Discord サーバーID を設定
# 未設定の場合はグローバル同期（反映まで最大1時間）
# GUILD_ID=123456789012345678

# エラー/警告/起動通知を送信する Discord Webhook URL（任意）
# 未設定の場合は通知機能が無効になります
# ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/...

# オーナーユーザーID（カンマ区切りで複数指定可）（任意）
# 未設定の場合はオーナーコマンドが使用不可になります
# 複数指定例: OWNER_IDS=111111111111111111,222222222222222222
# OWNER_IDS=811515262238064640

# Botのオンラインステータス（online / idle / dnd / invisible）（任意）
# 未設定の場合は online になります
# BOT_STATUS=online
